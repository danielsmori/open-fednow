<?xml version="1.0" encoding="UTF-8"?>
<!--
  OWASP dependency-check suppressions.

  Every entry here is a documented decision that a specific CVE (or CPE
  match) does not apply to this project. Suppressions must include:
    - the CVE or vulnerabilityName being suppressed,
    - a filePath / packageUrl scoping the suppression to one artifact,
    - a <notes> block explaining WHY it does not apply.

  Suppression is not exemption. When Spring Boot's next patch release
  bumps the underlying artifact past the CVE, remove the suppression
  and re-run the scan to confirm.
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

  <!-- ────────────────────────────────────────────────────────────────────
       swagger-ui bundled DOMPurify (client-side JavaScript)
       ─────────────────────────────────────────────────────────────────── -->
  <suppress>
    <notes><![CDATA[
      DOMPurify is a browser-only DOM sanitizer, bundled inside swagger-ui's
      JS files. It executes in the user's browser when a developer opens
      /swagger-ui.html locally to explore the API; it never runs server-side.
      CVEs against DOMPurify describe XSS vectors triggered by malicious
      HTML input in a browser session — a threat model that has no analog
      here (we don't accept or render untrusted HTML anywhere in the app).
      Removing swagger-ui to satisfy this scanner would drop the interactive
      API docs, which are the primary integrator on-ramp; the risk/benefit
      does not favour that.

      Revisit if swagger-ui ships an updated DOMPurify (currently blocked by
      swagger-ui's own release cadence, tracked in swagger-api/swagger-ui).
    ]]></notes>
    <packageUrl regex="true">^pkg:javascript/DOMPurify@.*$</packageUrl>
